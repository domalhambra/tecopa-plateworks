# Python
.venv/
# isolated region-prep stack (requirements-regionprep.txt)
.venv-prep/
__pycache__/
*.py[cod]
.pytest_cache/

# The DEM is the one large regenerable asset (see sources.json to verify a rebuild).
# landcover.tif is small (<1 MB) and IS committed -- no broad *.tif rule.
regions/*/dem.tif

# requests-cache from the NHD/3DEP fetches
cache/

# user-uploaded marker photos (single-user local app) — root only, so it
# doesn't swallow doc folders that happen to contain an "uploads/" subdir
/uploads/

# server-foundation local stores (blob outputs + sqlite session db)
blobs/
*.db

# OS
.DS_Store
