{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/hd/**",
              "screens.jsx",
              "ui_kits/badwater-hd/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Lora))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Lora."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:outline|solid|gold|neutral|success)$/]",
        "message": "<Badge> tone must be one of 'outline' | 'solid' | 'gold' | 'neutral' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|href|disabled|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, href, disabled, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|gold|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'gold' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Button> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:context|note|bespoke)$/]",
        "message": "<Callout> variant must be one of 'context' | 'note' | 'bespoke'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CardChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<CardChip> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='CenterBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:center|state|label|key|ref|className|style|children)$/]",
        "message": "<CenterBadge> doesn't accept that prop. Declared props: center, state, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='CenterBadge'] > JSXAttribute[name.name='center'] > Literal[value!=/^(?:head|ajna|throat|g-center|heart-ego|sacral|solar-plexus|spleen|root)$/]",
        "message": "<CenterBadge> center must be one of 'head' | 'ajna' | 'throat' | 'g-center' | 'heart-ego' | 'sacral' | 'solar-plexus' | 'spleen' | 'root'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CenterBadge'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:defined|open)$/]",
        "message": "<CenterBadge> state must be one of 'defined' | 'open'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|href|active|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: as, href, active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:a|span)$/]",
        "message": "<Chip> as must be one of 'a' | 'span'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeepDive'] > JSXAttribute > JSXIdentifier[name!=/^(?:summary|defaultOpen|children|key|ref|className|style|children)$/]",
        "message": "<DeepDive> doesn't accept that prop. Declared props: summary, defaultOpen, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|as|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|muted|gold)$/]",
        "message": "<Eyebrow> tone must be one of 'accent' | 'muted' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:div|span|p)$/]",
        "message": "<Eyebrow> as must be one of 'div' | 'span' | 'p'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|showStrategy|key|ref|className|style|children)$/]",
        "message": "<TypeBadge> doesn't accept that prop. Declared props: type, showStrategy."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeBadge'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:manifestor|generator|manifesting-generator|projector|reflector)$/]",
        "message": "<TypeBadge> type must be one of 'manifestor' | 'generator' | 'manifesting-generator' | 'projector' | 'reflector'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
